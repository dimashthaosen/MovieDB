# Copy this file to ".env" and paste your keys below.

# TMDb — for loading movie data (free). https://www.themoviedb.org/settings/api
# Use the "API Key (v3 auth)" value.
TMDB_API_KEY=your_key_here

# OpenRouter — for the AI companion (paid). https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here
# Optional: override the model (default is google/gemini-3.1-flash-lite:online)
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite:online
